    <parent link="base_link"/>
    <child link="lb1"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.14" upper="3.14" effort="6" velocity="10.467"/>
  </joint>

  <link name="lb2">
    <inertial>
      <origin xyz="-0.00043375 0.05495689 -0.00971555" rpy="0 0 0"/>
      <mass value="0.41571"/>
      <inertia ixx="0.00055768" ixy="5.8E-07" ixz="-6.79E-06" iyy="0.00041688" iyz="9.683E-05" izz="0.00027342"/>
    </inertial>
    <visual>
