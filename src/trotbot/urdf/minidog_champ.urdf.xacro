      <geometry>
        <box size="0.03 0.03 0.05"/>
      </geometry>
    </collision>
  </link>
  <joint name="rf1_rf2" type="revolute">
    <origin xyz="0.037 -0.098 0" rpy="0 0 0"/>
    <parent link="rf1"/>
    <child link="rf2"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.6167" upper="2.6167" effort="6" velocity="10.467"/>
  </joint>

  <link name="rf3">
    <inertial>
      <origin xyz="0.00275232 0 -0.02972173" rpy="0 0 0"/>
      <mass value="0.045248"/>
      <inertia ixx="7.175E-05" ixy="0" ixz="3.98E-06" iyy="7.314E-05" iyz="0" izz="3.66E-06"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_dir}/rf_calf.STL"/>
      </geometry>
