    </collision>
  </link>
  <joint name="lf3_lffoot" type="fixed">
    <origin xyz="0 0 -0.12589" rpy="0 0 0"/>
    <parent link="lf3"/>
    <child link="lffoot"/>
  </joint>

  <!-- Right front -->
  <link name="rf1">
    <inertial>
      <origin xyz="0.03515121 0.00140177 -9.224E-05" rpy="0 0 0"/>
      <mass value="0.28323"/>
      <inertia ixx="8.573E-05" ixy="-1.77E-06" ixz="9E-08" iyy="9.68E-05" iyz="4.9E-07" izz="9.864E-05"/>
