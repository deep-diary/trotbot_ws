      <origin xyz="-0.0005743 -0.00010766 -0.0027789" rpy="0 0 0"/>
      <mass value="0.014945"/>
      <inertia ixx="1E-06" ixy="0" ixz="6E-08" iyy="1.06E-06" iyz="0" izz="1.3E-06"/>
