    <collision>
      <origin xyz="0.00275232 0 -0.02972173" rpy="0 0 0"/>
      <geometry>
        <box size="0.015 0.015 0.05"/>
      </geometry>
    </collision>
  </link>
  <joint name="lf2_lf3" type="revolute">
    <origin xyz="0 0 -0.105" rpy="0 0 0"/>
    <parent link="lf2"/>
    <child link="lf3"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.5469" upper="-0.48844" effort="6" velocity="10.467"/>
  </joint>

  <link name="lffoot">
    <inertial>
      <origin xyz="-0.0005743 -0.00010766 -0.0027789" rpy="0 0 0"/>
      <mass value="0.014945"/>
      <inertia ixx="1E-06" ixy="0" ixz="6E-08" iyy="1.06E-06" iyz="0" izz="1.3E-06"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_dir}/lf_foot.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.75294 0.75294 0.75294 1"/>
