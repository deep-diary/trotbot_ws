<?xml version="1.0"?>
<!-- Minidog geometry with Champ/trotbot names. Champ IK uses only lower_leg.x and lower_leg.z for link length (see
     champ/kinematics/kinematics.h); knee y offset is folded into lf1_lf2. Thigh STL still mounts at original CAD spacing:
     pull thigh mesh along -y (left legs) / +y (right legs) by 0.081 m so hip bracket meets body; calf mesh offset reset. -->
<robot name="trotbot" xmlns:xacro="http://ros.org/wiki/xacro">
  <xacro:property name="mesh_dir" value="file://$(find trotbot)/meshes/minidog"/>
  <xacro:property name="knee_y_merged" value="0.081"/>

  <link name="base_link">
    <inertial>
      <origin xyz="0.00821482 0.00020218 0.00424442" rpy="0 0 0"/>
      <mass value="2.7673"/>
      <inertia ixx="0.00998124" ixy="9.82E-06" ixz="-0.00257876" iyy="0.02546149" iyz="-1.318E-05" izz="0.02812534"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_dir}/base.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.75294 0.75294 0.75294 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.194 0.16 0.07"/>
      </geometry>
    </collision>
    <collision>
      <origin xyz="0.2 0 0.03" rpy="0 1.57079632 0"/>
      <geometry>
        <cylinder length="0.025" radius="0.02"/>
      </geometry>
    </collision>
  </link>

  <!-- Left front -->
  <link name="lf1">
    <inertial>
      <origin xyz="0.03515121 -0.00140177 9.224E-05" rpy="0 0 0"/>
      <mass value="0.28323"/>
      <inertia ixx="8.573E-05" ixy="1.77E-06" ixz="-9E-08" iyy="9.68E-05" iyz="4.9E-07" izz="9.864E-05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_dir}/lf_hip.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.75294 0.75294 0.75294 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.03515121 -0.00140177 9.224E-05" rpy="1.57079632 0 0"/>
      <geometry>
        <cylinder radius="0.028" length="0.04"/>
      </geometry>
    </collision>
  </link>
  <joint name="base_lf1" type="revolute">
    <origin xyz="0.097 0.04 0" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="lf1"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.14" upper="3.14" effort="6" velocity="10.467"/>
  </joint>

  <link name="lf2">
    <inertial>
      <origin xyz="-0.00010595 0.05512752 -0.00907793" rpy="0 0 0"/>
      <mass value="0.42421"/>
      <inertia ixx="0.00057282" ixy="7.38E-06" ixz="-1.032E-05" iyy="0.00042725" iyz="0.00010651" izz="0.0002817"/>
    </inertial>
    <visual>
      <origin xyz="0 -${knee_y_merged} 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_dir}/lf_thigh.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.75294 0.75294 0.75294 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="-0.00010595 -0.02587248 -0.00907793" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.03 0.05"/>
      </geometry>
    </collision>
  </link>
  <joint name="lf1_lf2" type="revolute">
    <!-- 0.017 + 0.081 from original knee y (merged for Champ planar leg model) -->
    <origin xyz="0.037 0.098 0" rpy="0 0 0"/>
    <parent link="lf1"/>
    <child link="lf2"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.6167" upper="2.6167" effort="6" velocity="10.467"/>
  </joint>

  <link name="lf3">
    <inertial>
      <origin xyz="0.00275232 0 -0.02972173" rpy="0 0 0"/>
      <mass value="0.045248"/>
      <inertia ixx="7.175E-05" ixy="0" ixz="3.98E-06" iyy="7.314E-05" iyz="0" izz="3.66E-06"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_dir}/lf_calf.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.75294 0.75294 0.75294 1"/>
